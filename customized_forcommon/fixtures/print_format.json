  "css": "\r\n.print-format {\r\n    font-family: 'Arial', sans-serif;\r\n    font-size: 12px;\r\n    color: #333;\r\n}\r\n\r\n.print-format h2 {\r\n    text-align: center;\r\n    margin-bottom: 20px;\r\n    font-size: 20px;\r\n    text-transform: uppercase;\r\n    border-bottom: 2px solid #000;\r\n    padding-bottom: 5px;\r\n}\r\n\r\n.print-format p {\r\n    margin: 4px 0;\r\n}\r\n\r\n.print-format table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    margin-top: 15px;\r\n}\r\n\r\n.print-format th {\r\n    background-color: #f2f2f2;\r\n    border: 1px solid #ccc;\r\n    padding: 8px;\r\n    font-weight: bold;\r\n    text-align: center;\r\n}\r\n\r\n.print-format td {\r\n    border: 1px solid #ccc;\r\n    padding: 6px;\r\n}\r\n\r\n.print-format .no-border td {\r\n    border: none;\r\n    padding: 4px 6px;\r\n}\r\n\r\n.print-format .text-right {\r\n    text-align: right;\r\n}\r\n\r\n.print-format .text-center {\r\n    text-align: center;\r\n}\r\n\r\n.print-format .total-summary {\r\n    margin-top: 30px;\r\n    font-size: 13px;\r\n    border-top: 2px solid #000;\r\n    padding-top: 10px;\r\n}\r\n\r\n",
