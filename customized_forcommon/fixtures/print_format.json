  "format_data": null,
  "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Purchase Receipt</title>\r\n    <style>\r\n        body {\r\n            font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif;\r\n            margin: 40px;\r\n            color: #333;\r\n            background: #fdfdfd;\r\n        }\r\n\r\n        h2 {\r\n            text-align: center;\r\n            margin-bottom: 30px;\r\n            font-size: 28px;\r\n            color: #2c3e50;\r\n        }\r\n\r\n        p {\r\n            margin: 6px 0;\r\n            font-size: 14px;\r\n        }\r\n\r\n        strong {\r\n            color: #2d3436;\r\n        }\r\n\r\n        table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 25px;\r\n            background: #ffffff;\r\n            font-size: 14px;\r\n        }\r\n\r\n        th, td {\r\n            \r\n            padding: 10px;\r\n            text-align: left;\r\n            vertical-align: top;\r\n        }\r\n\r\n        th {\r\n            background-color: #f0f0f0;\r\n            color: #2c3e50;\r\n            font-weight: bold;\r\n        }\r\n\r\n        td small {\r\n            color: #636e72;\r\n            display: block;\r\n            margin-top: 2px;\r\n        }\r\n\r\n        hr {\r\n            margin: 30px 0;\r\n            border: none;\r\n            border-top: 1px solid #ccc;\r\n        }\r\n        .totals {\r\n            text-align: right;\r\n            margin-top: 20px;\r\n        }\r\n        \r\n        .totals p {\r\n            font-weight: normal;\r\n            font-size: 14px;\r\n            margin: 4px 0;\r\n        }\r\n        \r\n        .totals p strong {\r\n            font-weight: bold;\r\n        }\r\n        \r\n        .totals .normal {\r\n            font-weight: normal;\r\n        }\r\n\r\n        /* Optional Signature Boxes */\r\n        .signatures {\r\n            display: flex;\r\n            justify-content: space-between;\r\n            margin-top: 50px;\r\n        }\r\n\r\n        .sign-box {\r\n            width: 30%;\r\n            text-align: center;\r\n            padding-top: 5px;\r\n            font-size: 14px;\r\n        }\r\n\r\n        /* Optional Footer Image */\r\n        .footer {\r\n            margin-top: 60px;\r\n            text-align: center;\r\n        }\r\n\r\n        .footer-img {\r\n            width: 100%;\r\n            max-height: 100px;\r\n            object-fit: contain;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n<!-- Header Image -->\r\n    <img class=\"header-img\" src=\"/files/header.png\" alt=\"Header Image\">\r\n    <h2>Purchase Receipt</h2>\r\n    <p><strong>Receipt No:</strong> {{ doc.name }}</p>\r\n    <p><strong>Date:</strong> {{ doc.posting_date }}</p>\r\n    <p><strong>Supplier Name:</strong> {{ doc.supplier_name }}</p>\r\n    <p><strong>Req.Department:</strong> {{ doc.custom_department or \"\" }}</p>\r\n    <p><strong>Purchase Order:</strong> {{ doc.custom_purchase_order }}</p>\r\n\r\n    <table>\r\n        <thead>\r\n            <tr>\r\n                <th>Sr</th>\r\n                <th>Description</th>\r\n                <th>Accepted Quantity</th>\r\n                <th>Rate</th>\r\n                <th>Amount</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% for item in doc.items %}\r\n            <tr>\r\n                <td>{{ loop.index }}</td>\r\n                <td>\r\n                    {{ item.item_name }}<br>\r\n                    <small>UOM: {{ item.uom }}</small>\r\n                    <small>Rate of Stock UOM: {{ item.valuation_rate }} Br</small>\r\n                    <small>Expense Account: {{ item.expense_account }}</small>\r\n                </td>\r\n                <td>{{ item.qty }}</td>\r\n                <td>{{ item.rate }} Br</td>\r\n                <td>{{ item.amount }} Br</td>\r\n            </tr>\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <div class=\"totals\">\r\n        <p><strong>Total:</strong> <span class=\"normal\">{{ doc.total }} Br</span></p>\r\n        <p><strong>VAT Receivable:</strong> <span class=\"normal\">{{ doc.total_taxes_and_charges}} Br</span></p>\r\n        <p><strong>Grand Total:</strong> <span class=\"normal\">{{ doc.grand_total }} Br</span></p>\r\n        <p><strong>In Words:</strong> <span class=\"normal\">{{ doc.in_words }}</span></p>\r\n    </div>\r\n    <hr>\r\n\r\n\r\n    <!-- Optional Signature Section -->\r\n    <div class=\"signatures\">\r\n        <div class=\"sign-box\"><p><strong>Purchaser Name:</strong> {{ doc.custom_purchaser_name }}</p></div>\r\n        <div class=\"sign-box\"><p><strong>Purchase Receipter:</strong> {{ frappe.get_fullname(doc.owner) }}</p></div>\r\n        <div class=\"sign-box\"><p><strong>Submitted Date:</strong> {{ doc.creation }}</p></div>\r\n    </div>\r\n\r\n    <!-- Optional Footer Image -->\r\n    {% if footer %}\r\n        <br><br><br>\r\n        <div class=\"footer\" style=\"margin-top: 10px; font-size: 10px; text-align: center;\">\r\n            <br><br><br><br><br><br>\r\n            {{ footer }}\r\n         </div>\r\n    {% endif %}\r\n\r\n</body>\r\n</html>\r\n",
