  "font": null,
  "font_size": 14,
  "format_data": null,
  "html": "<style>\r\n@media print {\r\n    @page {\r\n        size: A4 portrait;\r\n        margin: 20mm;\r\n    }\r\n    body {\r\n        font-size: 12px;\r\n        font-family: Arial, sans-serif;\r\n        -webkit-print-color-adjust: exact;\r\n        print-color-adjust: exact;\r\n    }\r\n    h2 {\r\n        font-size: 18px;\r\n    }\r\n    table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n    }\r\n    td {\r\n        padding: 4px;\r\n        vertical-align: top;\r\n    }\r\n}\r\n</style>\r\n\r\n{% if letter_head and not no_letterhead -%}\r\n<div class=\"letter-head\">{{ letter_head }}</div>\r\n<hr>\r\n{%- endif %}\r\n\r\n<div style=\"color: black;\">\r\n\r\n    <h2 style=\"text-align: center; background-color: #F2F2F2; padding: 6px;\">PURCHASE ORDER</h2>\r\n    <div style=\"text-align: right; margin-top: 20px;\">\r\n        <strong>Purchase Order ID:</strong> {{ doc.name }}\r\n    </div>\r\n    <div style=\"text-align: right; margin-top: 20px;\">\r\n        <strong>Date:</strong> {{ frappe.utils.formatdate(frappe.utils.today()) }}\r\n    </div>\r\n\r\n    <table style=\"margin-top: 10px; font-size: 12px;\">\r\n        <tr>\r\n            <td><strong>Supplier:</strong></td>\r\n            <td>{{ doc.supplier_name }}</td>\r\n            <td></td>\r\n            <td></td>\r\n            <td><strong>File_No:</strong></td>\r\n            <td>{{ doc.custom_file_no }}</td>\r\n            <td></td>\r\n            <td></td>\r\n            <td><strong>Delivery Date:</strong></td>\r\n            <td>{{ frappe.utils.formatdate(doc.schedule_date) }}</td>\r\n        </tr>\r\n        <tr>\r\n            <td><strong>Purchased Method:</strong></td>\r\n            <td>{{ doc.custom_purchase_method }}</td>\r\n            <td></td>\r\n            <td></td>\r\n            <td><strong>Purchased By</strong></td>\r\n            <td>{{ doc.custom_purchaser_name }}</td>\r\n        </tr>\r\n        </table>\r\n        </br>\r\n        </br>\r\n    <h3>Item Details</h3>\r\n    <table style=\"margin-top: 10px; font-size: 12px;\">\r\n        <tr>\r\n            <td><strong>Item:</strong></td>\r\n            <td></td>\r\n        \r\n            <td><strong>Qty:</strong></td>\r\n            <td></td>\r\n           \r\n            <td><strong>UOM:</strong></td>\r\n            <td></td>\r\n            \r\n            <td><strong>Rate:</strong></td>\r\n            <td></td>\r\n            <td><strong>Amount:</strong></td>\r\n        </tr>\r\n        <tr>\r\n            <td> {% for item in doc.items %}{{ item.item_name }}{% endfor %} </td>\r\n            <td></td>\r\n            \r\n            <td>{% for item in doc.items %}{{ item.qty }}{% endfor %} </td>\r\n            <td></td>\r\n            \r\n            <td>{% for item in doc.items %}{{ item.uom }}{% endfor %} </td>\r\n            <td></td>\r\n            \r\n            <td>{% for item in doc.items %}{{ item.rate }}{% endfor %} </td>\r\n            <td></td>\r\n            \r\n            <td>{% for item in doc.items %}{{ item.amount }}{% endfor %} </td>\r\n        </tr>\r\n        <tr>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td><strong>Total TAX:</strong></td>\r\n            <td>{%for tax in doc.taxes %}{{ tax.tax_amount }}{% endfor %}</td>\r\n        </tr>\r\n        <tr>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td><strong>Total Amount:</strong></td>\r\n            <td>{{ frappe.utils.fmt_money(doc.grand_total) }} Birr</td>\r\n        </tr>\r\n        <tr>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td></td>\r\n            <td><strong>Amount in Words:</strong></td>\r\n            <td>{{ frappe.utils.money_in_words(doc.grand_total) }}</td>\r\n        </tr>\r\n    </table>\r\n\r\n    <br>\r\n</br></br>\r\n<table style=\"text-align: center; font-size: 12px; width: 100%; margin: 0 auto;\">\r\n    <tr>\r\n        <td style=\"text-align: center; padding: 8px;\"><strong><u>Requested By</u></strong></td>\r\n        <td style=\"text-align: center; padding: 8px;\"><strong><u>Checked By</u></strong></td>\r\n        <td style=\"text-align: center; padding: 8px;\"><strong><u>Approved By</u></strong></td>\r\n    </tr>\r\n    <tr>\r\n        <td style=\"text-align: center; padding: 8px;\">\r\n            {% set requested_action = frappe.db.get_value(\"Workflow Action\", {\"reference_doctype\": \"Purchase Order\", \"reference_name\": doc.name, \"workflow_state\": \"Draft\"}, [\"owner\", \"creation\"]) %}\r\n            {% set requested_by = requested_action[0] if requested_action else None %}\r\n            {% set requested_date = requested_action[1] if requested_action else None %}\r\n            {% set requested_full_name = frappe.db.get_value(\"User\", requested_by, \"full_name\") or \"Not Requested\" %}\r\n            <strong>Name:</strong> {{ requested_full_name }}<br><br>\r\n            <strong>Date:</strong> {{ frappe.utils.formatdate(requested_date) if requested_date else \"________________\" }}\r\n        </td>\r\n        <td style=\"text-align: center; padding: 8px;\">\r\n            {% set reviewed_action = frappe.db.get_value(\"Workflow Action\", {\"reference_doctype\": \"Purchase Order\", \"reference_name\": doc.name, \"workflow_state\": \"On Hold\"}, [\"owner\", \"creation\"]) %}\r\n            {% set reviewed_by = reviewed_action[0] if reviewed_action else None %}\r\n            {% set reviewed_date = reviewed_action[1] if reviewed_action else None %}\r\n            {% set reviewed_full_name = frappe.db.get_value(\"User\", reviewed_by, \"full_name\") or \"Not Reviewed\" %}\r\n            <strong>Name:</strong> {{ reviewed_full_name }}<br><br>\r\n            <strong>Date:</strong> {{ frappe.utils.formatdate(reviewed_date) if reviewed_date else \"________________\" }}\r\n        </td>\r\n        <td style=\"text-align: center; padding: 8px;\">\r\n            {% set approved_action = frappe.db.get_value(\"Workflow Action\", {\"reference_doctype\": \"Purchase Order\", \"reference_name\": doc.name, \"workflow_state\": \"To Receive and Bill\"}, [\"owner\", \"creation\"]) %}\r\n            {% set approved_by = approved_action[0] if approved_action else None %}\r\n            {% set approved_date = approved_action[1] if approved_action else None %}\r\n            {% set approved_full_name = frappe.db.get_value(\"User\", approved_by, \"full_name\") or \"Not Approved\" %}\r\n            <strong>Name:</strong>{{approved_full_name}}<br><br>\r\n            <strong>Date:</strong> {{ frappe.utils.formatdate(approved_date) if approved_date else \"________________\" }}\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n{% if footer %}\r\n<br><br><br>\r\n<div class=\"footer\" style=\"margin-top: 10px; font-size: 10px; text-align: center;\">\r\n    <br><br><br><br><br><br>\r\n    {{ footer }}\r\n</div>\r\n{% endif %}\r\n</div>\r\n",
