  "format_data": null,
  "html": "<!-- Custom Quotation Print Format -->\r\n\r\n<style>\r\n    .print-format table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n    }\r\n    .print-format th, .print-format td {\r\n        border: 1px solid #000;\r\n        padding: 6px;\r\n        font-size: 12px;\r\n    }\r\n    .print-format .no-border td {\r\n        border: none;\r\n    }\r\n    .print-format .text-right {\r\n        text-align: right;\r\n    }\r\n    .print-format .text-center {\r\n        text-align: center;\r\n    }\r\n</style>\r\n<div style=\"text-align: center; margin-bottom: 10px;\">\r\n    <img src=\"/files/header.png\" style=\"max-width: 100%; height: auto;\">\r\n</div>\r\n<h2 class=\"text-center\">Quotation</h2>\r\n<p><strong>Quotation No:</strong> {{ doc.name }}</p>\r\n<p><strong>Customer Name:</strong> {{ doc.customer_name }}</p>\r\n<p><strong>Date:</strong> {{ frappe.utils.formatdate(doc.transaction_date) }}</p>\r\n<p><strong>Valid Till:</strong> {{ frappe.utils.formatdate(doc.valid_till) }}</p>\r\n<!-- Bank Info -->\r\n<div style=\"margin: 20px 0;\">\r\n    <strong>CBE Account Number:</strong> 1000617721191\r\n</div>\r\n\r\n<table class=\"table table-bordered\">\r\n    <thead>\r\n        <tr>\r\n            <th>Sr</th>\r\n            <th>Description</th>\r\n            <th>Quantity</th>\r\n            <th>Rate</th>\r\n            <th>Amount</th>\r\n        </tr>\r\n    </thead>\r\n    <tbody>\r\n        {% set total_qty = [] %}\r\n        {% for i, item in enumerate(doc.items) %}\r\n        <tr>\r\n            <td>{{ i + 1 }}</td>\r\n            <td>\r\n                {{ item.item_code }}<br>\r\n                {{ item.item_name }}<br>\r\n                <small><strong>UOM:</strong> {{ item.uom }}</small><br>\r\n            </td>\r\n            <td>{{ item.qty }}</td>\r\n            <td>{{ frappe.utils.fmt_money(item.rate) }}</td>\r\n            <td>{{ frappe.utils.fmt_money(item.amount) }}</td>\r\n        </tr>\r\n        {% set _ = total_qty.append(item.qty) %}\r\n        {% endfor %}\r\n    </tbody>\r\n</table>\r\n\r\n<table class=\"no-border\" style=\"margin-top: 20px;\">\r\n    <tr>\r\n        <td><strong>Total Quantity:</strong></td>\r\n        <td>{{ total_qty | sum }}</td>\r\n    </tr>\r\n    <tr>\r\n        <td><strong>Total:</strong></td>\r\n        <td>{{ frappe.utils.fmt_money(doc.total) }}</td>\r\n    </tr>\r\n    <tr>\r\n        <td><strong>VAT @ 15.0:</strong></td>\r\n        <td>{{ frappe.utils.fmt_money(doc.taxes[0].tax_amount) if doc.taxes else '0.00' }}</td>\r\n    </tr>\r\n    <tr>\r\n        <td><strong>Grand Total:</strong></td>\r\n        <td>{{ frappe.utils.fmt_money(doc.grand_total) }}</td>\r\n    </tr>\r\n    <tr>\r\n        <td><strong>Rounded Total:</strong></td>\r\n        <td><strong>{{ frappe.utils.fmt_money(doc.rounded_total or doc.grand_total) }}</strong></td>\r\n    </tr>\r\n    <tr>\r\n        <td><strong>In Words:</strong></td>\r\n        <td>{{ doc.in_words }}</td>\r\n    </tr>\r\n</table>\r\n\r\n{% if footer %}\r\n    <br><br><br>\r\n    <div class=\"footer\" style=\"margin-top: 10px; font-size: 10px; text-align: center;\">\r\n        <br><br><br><br><br><br>\r\n        {{ footer }}\r\n    </div>\r\n{% endif %}\r\n",
