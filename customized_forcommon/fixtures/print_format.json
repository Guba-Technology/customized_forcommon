 {
  "absolute_value": 0,
  "align_labels_right": 0,
  "css": null,
  "custom_format": 1,
  "default_print_language": "en",
  "disabled": 0,
  "doc_type": "Stock Entry",
  "docstatus": 0,
  "doctype": "Print Format",
  "font": null,
  "font_size": 14,
  "format_data": null,
  "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Stock Entry</title>\r\n    <style>\r\n        body {\r\n            font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif;\r\n            margin: 40px;\r\n            color: #333;\r\n            background: #f9f9f9;\r\n        }\r\n        .header-img, .footer-img {\r\n            width: 100%;\r\n            height: auto;\r\n            margin-bottom: 20px;\r\n        }\r\n        .header {\r\n            text-align: center;\r\n            color: #2e7d32;\r\n            font-size: 24px;\r\n            font-weight: bold;\r\n            margin: 10px 0 30px;\r\n        }\r\n        .two-row-container {\r\n            display: flex;\r\n            flex-wrap: wrap;\r\n            justify-content: space-between;\r\n            margin-bottom: 20px;\r\n        }\r\n        .two-row-container div {\r\n            width: 48%;\r\n            font-size: 14px;\r\n            margin-bottom: 6px;\r\n        }\r\n        .label {\r\n            font-weight: bold;\r\n            color: #444;\r\n        }\r\n        .section-title {\r\n            font-size: 18px;\r\n            font-weight: bold;\r\n            color: #2e7d32;\r\n            margin-top: 30px;\r\n            margin-bottom: 10px;\r\n        }\r\n        table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            background-color: #fff;\r\n            margin-bottom: 20px;\r\n        }\r\n        th, td {\r\n            border: 1px solid #ccc;\r\n            padding: 8px 10px;\r\n            text-align: center;\r\n            font-size: 13px;\r\n        }\r\n        th {\r\n            background-color: #e0f2f1;\r\n            color: #000;\r\n        }\r\n        .total-amount {\r\n            font-weight: bold;\r\n            text-align: right;\r\n            font-size: 16px;\r\n            margin: 10px 0;\r\n        }\r\n        .signatures {\r\n    display: flex;\r\n    justify-content: space-around;\r\n    margin-top: 80px; /* space before signature area */\r\n    margin-bottom: 60px; /* space between signature and footer image */\r\n        }\r\n        .sign-box {\r\n            width: 30%;\r\n            text-align: center;\r\n            border-top: 1px solid #000;\r\n            padding-top: 6px;\r\n            font-size: 14px;\r\n        }\r\n        .footer {\r\n        position: fixed;\r\n        bottom: 0;\r\n        left: 0;\r\n        right: 0;\r\n        height: 80px;\r\n        text-align: center;\r\n        font-size: 12px;\r\n        padding: 10px;\r\n        border-top: 1px solid #ccc;\r\n        background-color: #fff;\r\n    }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n    <!-- Header Image -->\r\n    <img class=\"header-img\" src=\"/files/header.png\" alt=\"Header Image\">\r\n\r\n    <div class=\"header\">Stock Entry</div>\r\n\r\n    <!-- Stock Entry Info -->\r\n    <div class=\"two-row-container\">\r\n        <div><span class=\"label\">Stock Entry ID:</span> {{ doc.name }}</div>\r\n        <div>\r\n            <span class=\"label\">Material Request ID:</span>\r\n            {% set mr_displayed = false %}\r\n            {% for item in doc.items %}\r\n                {% if item.material_request %}\r\n                    {{ item.material_request }}\r\n                    {% set mr_displayed = true %}\r\n                   \r\n                {% endif %}\r\n            {% endfor %}\r\n            {% if not mr_displayed %} N/A {% endif %}\r\n        </div>\r\n        <div><span class=\"label\">Stock Entry Type:</span> {{ doc.stock_entry_type }}</div>\r\n        <div><span class=\"label\">Purpose:</span> {{ doc.purpose }}</div>\r\n        <div><span class=\"label\">Posting Date:</span> {{ doc.posting_date }}</div>\r\n        <div><span class=\"label\">Process Loss %:</span> {{ doc.process_loss_percentage }}%</div>\r\n        <div><span class=\"label\">Process Loss Qty:</span> {{ doc.process_loss_qty }}</div>\r\n    </div>\r\n\r\n  {% if doc.purpose == \"Manufacture\" %}\r\n    <!-- Issued Materials -->\r\n    <div class=\"section-title\">Issued Materials</div>\r\n    <table>\r\n        <thead>\r\n            <tr>\r\n                <th>Sr</th>\r\n                <th>Description</th>\r\n                <th>Qty</th>\r\n                <th>Rate</th>\r\n                <th>Amount</th>\r\n                <th>Source Warehouse</th>\r\n                <th>Item Group</th>\r\n                <th>UOM</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% set total_issued = 0 %}\r\n            {% set issued_count = 1 %}\r\n            {% for item in doc.items %}\r\n                {% if not item.t_warehouse %}\r\n                <tr>\r\n                    <td>{{ issued_count }}</td>\r\n                    <td>{{ item.item_code }} - {{ item.item_name }}</td>\r\n                    <td>{{ item.qty }}</td>\r\n                    <td>{{ item.valuation_rate }}</td>\r\n                    <td>{{ item.qty * item.valuation_rate }}</td>\r\n                    <td>{{ item.s_warehouse or 'All warehouse - DEIC' }}</td>\r\n                    <td>{{ item.item_group }}</td>\r\n                    <td>{{ item.uom }}</td>\r\n                </tr>\r\n                {% endif %}\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <div class=\"total-amount\">Total Issued Amount: Br {{ doc.total_outgoing_value }}</div>\r\n\r\n    <!-- Finished Products -->\r\n    <div class=\"section-title\">Finished Products</div>\r\n    <table>\r\n        <thead>\r\n            <tr>\r\n                <th>Sr</th>\r\n                <th>Description</th>\r\n                <th>Qty</th>\r\n                <th>Rate</th>\r\n                <th>Amount</th>\r\n                <th>Target Warehouse</th>\r\n                <th>Item Group</th>\r\n                <th>UOM</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% set finished_count = 1 %}\r\n            {% for item in doc.items %}\r\n                {% if item.t_warehouse %}\r\n                <tr>\r\n                    <td>{{ finished_count }}</td>\r\n                    <td>{{ item.item_code }} - {{ item.item_name }}</td>\r\n                    <td>{{ item.qty }}</td>\r\n                    <td>{{ item.valuation_rate }}</td>\r\n                    <td>{{ item.qty * item.valuation_rate }}</td>\r\n                    <td>{{ item.t_warehouse }}</td>\r\n                    <td>{{ item.item_group }}</td>\r\n                    <td>{{ item.uom }}</td>\r\n                </tr>\r\n                {% set finished_count = finished_count + 1 %}\r\n                {% endif %}\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n <div class=\"total-amount\">Total Incoming Amount: Br {{ doc.total_incoming_value }}</div>\r\n{% elif doc.purpose == \"Material Transfer\" %}\r\n    <!-- Material Transfer Items -->\r\n    <div class=\"section-title\">Transferred Items</div>\r\n    <table>\r\n        <thead>\r\n            <tr>\r\n                <th>Sr</th>\r\n                <th>Description</th>\r\n                <th>Qty</th>\r\n                <th>Rate</th>\r\n                <th>Amount</th>\r\n                <th>Source Warehouse</th>\r\n                <th>Target Warehouse</th>\r\n                <th>Item Group</th>\r\n                <th>UOM</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% set total_transfer = 0 %}\r\n            {% for item in doc.items %}\r\n            <tr>\r\n                <td>{{ loop.index }}</td>\r\n                <td>{{ item.item_code }} - {{ item.item_name }}</td>\r\n                <td>{{ item.qty }}</td>\r\n                <td>{{ item.valuation_rate }}</td>\r\n                <td>{{ item.qty * item.valuation_rate }}</td>\r\n                <td>{{ item.s_warehouse or 'N/A' }}</td>\r\n                <td>{{ item.t_warehouse or 'N/A' }}</td>\r\n                <td>{{ item.item_group }}</td>\r\n                <td>{{ item.uom }}</td>\r\n            </tr>\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <div class=\"total-amount\">Total Transfer Amount: Br {{ doc.total_outgoing_value }}</div>\r\n\r\n{% else %}\r\n    <!-- Generic Case for Other Purposes -->\r\n    <div class=\"section-title\">Stock Entry Items</div>\r\n    <table>\r\n        <thead>\r\n            <tr>\r\n                <th>Sr</th>\r\n                <th>Description</th>\r\n                <th>Qty</th>\r\n                <th>Rate</th>\r\n                <th>Amount</th>\r\n                <th>Source Warehouse</th>\r\n                <th>Target Warehouse</th>\r\n                <th>Item Group</th>\r\n                <th>UOM</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% set total_generic = 0 %}\r\n            {% for item in doc.items %}\r\n            <tr>\r\n                <td>{{ loop.index }}</td>\r\n                <td>{{ item.item_code }} - {{ item.item_name }}</td>\r\n                <td>{{ item.qty }}</td>\r\n                <td>{{ item.valuation_rate }}</td>\r\n                <td>{{ item.qty * item.valuation_rate }}</td>\r\n                <td>{{ item.s_warehouse or 'N/A' }}</td>\r\n                <td>{{ item.t_warehouse or 'N/A' }}</td>\r\n                <td>{{ item.item_group }}</td>\r\n                <td>{{ item.uom }}</td>\r\n            </tr>\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <div class=\"total-amount\">Total Amount: Br {{ doc.total_outgoing_value }}</div>\r\n{% endif %}\r\n\r\n<!-- Signature Section -->\r\n<div class=\"signatures\">\r\n    <div class=\"sign-box\">Received By</div>\r\n    <div class=\"sign-box\">Reviewed By</div>\r\n    <div class=\"sign-box\">Approved By</div>\r\n</div>\r\n\r\n\r\n{% if footer %}\r\n    <br><br><br>\r\n    <div class=\"footer\" style=\"margin-top: 10px; font-size: 10px; text-align: center;\">\r\n        <br><br><br><br><br><br>\r\n        {{ footer }}\r\n    </div>\r\n{% endif %}\r\n\r\n\r\n</body>\r\n</html>\r\n",
